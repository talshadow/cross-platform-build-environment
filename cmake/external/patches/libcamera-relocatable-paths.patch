diff --git a/src/libcamera/source_paths.cpp b/src/libcamera/source_paths.cpp
index 1af5386..aa4328e 100644
--- a/src/libcamera/source_paths.cpp
+++ b/src/libcamera/source_paths.cpp
@@ -134,6 +134,36 @@ std::string libcameraSourcePath()
 	return path + "/";
 }
 
+/**
+ * \brief Retrieve the install prefix of the libcamera shared library
+ *
+ * Uses dladdr() to locate libcamera.so at runtime and returns the install
+ * prefix directory (the parent of the lib/ directory containing the .so).
+ * Unlike libcameraBuildPath(), this works for installed builds and makes
+ * resource paths fully relocatable — no absolute prefix baked in at build time.
+ *
+ * \return The install prefix with trailing slash, or an empty string on failure
+ */
+std::string libcameraInstalledPrefix()
+{
+	Dl_info info;
+
+	int ret = dladdr(reinterpret_cast<void *>(libcameraInstalledPrefix), &info);
+	if (ret == 0 || !info.dli_fname)
+		return std::string();
+
+	/* info.dli_fname = /prefix/lib/libcamera.so.x — go one level up to /prefix */
+	std::string path = std::string(dirname(info.dli_fname)) + "/..";
+
+	char *real = realpath(path.c_str(), nullptr);
+	if (!real)
+		return std::string();
+
+	path = real;
+	free(real);
+	return path + "/";
+}
+
 } /* namespace utils */
 
 } /* namespace libcamera */
