{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 23, "patch": 0 },

  "configurePresets": [

    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "base-cross",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "BUILD_TESTS": "OFF"
      }
    },

    {
      "name": "native-debug",
      "displayName": "Native — Debug",
      "description": "Нативна збірка системним компілятором, режим Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "native-release",
      "displayName": "Native — Release",
      "description": "Нативна збірка системним компілятором, режим Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_LTO": "ON"
      }
    },

    {
      "name": "native-relwithdebinfo",
      "displayName": "Native — RelWithDebInfo",
      "description": "Нативна збірка системним компілятором, Release з debug символами",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },

    {
      "name": "native-asan",
      "displayName": "Native — Debug + ASAN + UBSAN",
      "description": "Нативна збірка системним компілятором з санітайзерами",
      "inherits": "native-debug",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "ENABLE_UBSAN": "ON"
      }
    },

    {
      "name": "ubuntu2004-debug",
      "displayName": "Ubuntu 20.04 — Debug",
      "description": "Нативна збірка GCC 10, Ubuntu 20.04, режим Debug",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2004.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "UBUNTU2004_GCC_VERSION": "10"
      }
    },

    {
      "name": "ubuntu2004-release",
      "displayName": "Ubuntu 20.04 — Release",
      "description": "Нативна збірка GCC 10, Ubuntu 20.04, режим Release",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2004.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "UBUNTU2004_GCC_VERSION": "10",
        "ENABLE_LTO": "ON"
      }
    },

    {
      "name": "ubuntu2004-relwithdebinfo",
      "displayName": "Ubuntu 20.04 — RelWithDebInfo",
      "description": "Нативна збірка GCC 10, Ubuntu 20.04, Release з debug символами",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2004.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "UBUNTU2004_GCC_VERSION": "10"
      }
    },

    {
      "name": "ubuntu2404-debug",
      "displayName": "Ubuntu 24.04 — Debug",
      "description": "Нативна збірка GCC 13, Ubuntu 24.04, режим Debug",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2404.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "UBUNTU2404_GCC_VERSION": "13"
      }
    },

    {
      "name": "ubuntu2404-release",
      "displayName": "Ubuntu 24.04 — Release",
      "description": "Нативна збірка GCC 13, Ubuntu 24.04, режим Release",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2404.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "UBUNTU2404_GCC_VERSION": "13",
        "ENABLE_LTO": "ON"
      }
    },

    {
      "name": "ubuntu2404-relwithdebinfo",
      "displayName": "Ubuntu 24.04 — RelWithDebInfo",
      "description": "Нативна збірка GCC 13, Ubuntu 24.04, Release з debug символами",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Ubuntu2404.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "UBUNTU2404_GCC_VERSION": "13"
      }
    },

    {
      "name": "ubuntu2404-asan",
      "displayName": "Ubuntu 24.04 — Debug + ASAN + UBSAN",
      "description": "Debug збірка з санітайзерами для розробки",
      "inherits": "ubuntu2404-debug",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "ENABLE_UBSAN": "ON"
      }
    },

    {
      "name": "base-clang",
      "hidden": true,
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Clang.cmake"
    },

    {
      "name": "clang-debug",
      "displayName": "Clang — Debug",
      "description": "Нативна збірка системним Clang, режим Debug",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "clang-release",
      "displayName": "Clang — Release",
      "description": "Нативна збірка системним Clang, режим Release з ThinLTO",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_LTO": "ON"
      }
    },

    {
      "name": "clang-relwithdebinfo",
      "displayName": "Clang — RelWithDebInfo",
      "description": "Нативна збірка системним Clang, Release з debug символами",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },

    {
      "name": "clang-asan",
      "displayName": "Clang — Debug + ASAN + UBSAN",
      "description": "Clang Debug з AddressSanitizer та UBSanitizer",
      "inherits": "clang-debug",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "ENABLE_UBSAN": "ON"
      }
    },

    {
      "name": "clang-tsan",
      "displayName": "Clang — Debug + TSAN",
      "description": "Clang Debug з ThreadSanitizer для виявлення гонок даних",
      "inherits": "clang-debug",
      "cacheVariables": {
        "ENABLE_TSAN": "ON"
      }
    },

    {
      "name": "clang18-debug",
      "displayName": "Clang 18 — Debug",
      "description": "Нативна збірка Clang 18, режим Debug",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CLANG_VERSION": "18"
      }
    },

    {
      "name": "clang18-release",
      "displayName": "Clang 18 — Release",
      "description": "Нативна збірка Clang 18, режим Release з ThinLTO",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CLANG_VERSION": "18",
        "ENABLE_LTO": "ON"
      }
    },

    {
      "name": "clang18-asan",
      "displayName": "Clang 18 — Debug + ASAN + UBSAN",
      "description": "Clang 18 Debug з AddressSanitizer та UBSanitizer",
      "inherits": "clang18-debug",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "ENABLE_UBSAN": "ON"
      }
    },

    {
      "name": "rpi4-debug",
      "displayName": "Raspberry Pi 4 / 400 / CM4 — Debug",
      "description": "Крос-компіляція для BCM2711 (Cortex-A72, AArch64), режим Debug",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi4.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "rpi4-release",
      "displayName": "Raspberry Pi 4 / 400 / CM4 — Release",
      "description": "Крос-компіляція для BCM2711 (Cortex-A72, AArch64), режим Release",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi4.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "rpi4-relwithdebinfo",
      "displayName": "Raspberry Pi 4 / 400 / CM4 — RelWithDebInfo",
      "description": "Крос-компіляція для BCM2711 (Cortex-A72, AArch64), Release з debug символами",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi4.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },

    {
      "name": "rpi5-debug",
      "displayName": "Raspberry Pi 5 — Debug",
      "description": "Крос-компіляція для BCM2712 (Cortex-A76, AArch64), режим Debug",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi5.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "rpi5-release",
      "displayName": "Raspberry Pi 5 — Release",
      "description": "Крос-компіляція для BCM2712 (Cortex-A76, AArch64), режим Release",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi5.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "rpi5-relwithdebinfo",
      "displayName": "Raspberry Pi 5 — RelWithDebInfo",
      "description": "Крос-компіляція для BCM2712 (Cortex-A76, AArch64), Release з debug символами",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/RaspberryPi5.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },

    {
      "name": "yocto-debug",
      "displayName": "Yocto Linux — Debug",
      "description": "Крос-компіляція через Yocto SDK (активувати environment-setup-* перед використанням)",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Yocto.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "yocto-release",
      "displayName": "Yocto Linux — Release",
      "description": "Крос-компіляція через Yocto SDK (активувати environment-setup-* перед використанням)",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Yocto.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "yocto-relwithdebinfo",
      "displayName": "Yocto Linux — RelWithDebInfo",
      "description": "Крос-компіляція через Yocto SDK, Release з debug символами",
      "inherits": "base-cross",
      "toolchainFile": "${sourceDir}/cmake/toolchains/Yocto.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],

  "buildPresets": [
    { "name": "native-debug",          "configurePreset": "native-debug",          "jobs": 0 },
    { "name": "native-release",        "configurePreset": "native-release",        "jobs": 0 },
    { "name": "native-relwithdebinfo", "configurePreset": "native-relwithdebinfo", "jobs": 0 },
    { "name": "native-asan",           "configurePreset": "native-asan",           "jobs": 0 },
    { "name": "ubuntu2004-debug",          "configurePreset": "ubuntu2004-debug",          "jobs": 0 },
    { "name": "ubuntu2004-release",        "configurePreset": "ubuntu2004-release",        "jobs": 0 },
    { "name": "ubuntu2004-relwithdebinfo", "configurePreset": "ubuntu2004-relwithdebinfo", "jobs": 0 },
    { "name": "ubuntu2404-debug",          "configurePreset": "ubuntu2404-debug",          "jobs": 0 },
    { "name": "ubuntu2404-release",        "configurePreset": "ubuntu2404-release",        "jobs": 0 },
    { "name": "ubuntu2404-relwithdebinfo", "configurePreset": "ubuntu2404-relwithdebinfo", "jobs": 0 },
    { "name": "ubuntu2404-asan",           "configurePreset": "ubuntu2404-asan",           "jobs": 0 },
    { "name": "clang-debug",              "configurePreset": "clang-debug",              "jobs": 0 },
    { "name": "clang-release",            "configurePreset": "clang-release",            "jobs": 0 },
    { "name": "clang-relwithdebinfo",     "configurePreset": "clang-relwithdebinfo",     "jobs": 0 },
    { "name": "clang-asan",              "configurePreset": "clang-asan",              "jobs": 0 },
    { "name": "clang-tsan",              "configurePreset": "clang-tsan",              "jobs": 0 },
    { "name": "clang18-debug",           "configurePreset": "clang18-debug",           "jobs": 0 },
    { "name": "clang18-release",         "configurePreset": "clang18-release",         "jobs": 0 },
    { "name": "clang18-asan",            "configurePreset": "clang18-asan",            "jobs": 0 },
    { "name": "rpi4-debug",                "configurePreset": "rpi4-debug",                "jobs": 0 },
    { "name": "rpi4-release",              "configurePreset": "rpi4-release",              "jobs": 0 },
    { "name": "rpi4-relwithdebinfo",       "configurePreset": "rpi4-relwithdebinfo",       "jobs": 0 },
    { "name": "rpi5-debug",                "configurePreset": "rpi5-debug",                "jobs": 0 },
    { "name": "rpi5-release",              "configurePreset": "rpi5-release",              "jobs": 0 },
    { "name": "rpi5-relwithdebinfo",       "configurePreset": "rpi5-relwithdebinfo",       "jobs": 0 },
    { "name": "yocto-debug",               "configurePreset": "yocto-debug",               "jobs": 0 },
    { "name": "yocto-release",             "configurePreset": "yocto-release",             "jobs": 0 },
    { "name": "yocto-relwithdebinfo",      "configurePreset": "yocto-relwithdebinfo",      "jobs": 0 }
  ],

  "testPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4 }
    },
    {
      "name": "native-asan",
      "configurePreset": "native-asan",
      "output": { "outputOnFailure": true },
